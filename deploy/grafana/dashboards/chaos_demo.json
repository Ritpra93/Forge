{
  "uid": "forge-chaos-demo",
  "title": "Forge - Chaos Demo",
  "tags": ["forge", "chaos", "demo"],
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-10m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Leader Status per Node",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "forge_raft_is_leader{job=\"forge-scheduler\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Follower", "color": "red" }, "1": { "text": "Leader", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Elections (Last Minute)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(forge_raft_election_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Elections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Connected Workers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(forge_active_workers{job=\"forge-scheduler\"})",
          "legendFormat": "Workers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "Task Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(forge_tasks_submitted_total{job=\"forge-scheduler\"}[30s]))",
          "legendFormat": "Submitted/s"
        },
        {
          "expr": "sum(rate(forge_tasks_completed_total{job=\"forge-scheduler\"}[30s]))",
          "legendFormat": "Completed/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5
          },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Submitted/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Completed/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 5,
      "title": "Pending Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(forge_pending_queue_depth{job=\"forge-scheduler\"})",
          "legendFormat": "Pending Tasks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30
          },
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      }
    },
    {
      "id": 6,
      "title": "Worker Count Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(forge_active_workers{job=\"forge-scheduler\"})",
          "legendFormat": "Active Workers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "decimals": 0
        }
      }
    },
    {
      "id": 7,
      "title": "Raft Commit Index Convergence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "forge_raft_commit_index{job=\"forge-scheduler\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
