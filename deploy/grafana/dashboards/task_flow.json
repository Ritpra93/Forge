{
  "uid": "forge-task-flow",
  "title": "Forge - Task Flow",
  "tags": ["forge", "tasks"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Tasks per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(forge_tasks_submitted_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Submitted"
        },
        {
          "expr": "sum(rate(forge_tasks_completed_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Completed"
        },
        {
          "expr": "sum(rate(forge_tasks_failed_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5
          },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Submitted" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Status Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(forge_pending_queue_depth{job=\"forge-scheduler\"})",
          "legendFormat": "Pending"
        },
        {
          "expr": "sum(rate(forge_tasks_completed_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Completed/s"
        },
        {
          "expr": "sum(rate(forge_tasks_failed_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Failed/s"
        },
        {
          "expr": "sum(rate(forge_tasks_dead_lettered_total{job=\"forge-scheduler\"}[1m]))",
          "legendFormat": "Dead Letter/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 40,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Dead Letter/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "Task Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(forge_task_duration_seconds_bucket{job=\"forge-scheduler\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(forge_task_duration_seconds_bucket{job=\"forge-scheduler\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(forge_task_duration_seconds_bucket{job=\"forge-scheduler\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 4,
      "title": "Dead Lettered Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(forge_tasks_dead_lettered_total{job=\"forge-scheduler\"})",
          "legendFormat": "Dead Letters"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Pending Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(forge_pending_queue_depth{job=\"forge-scheduler\"})",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      }
    }
  ],
  "schemaVersion": 39
}
